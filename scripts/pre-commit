#!/usr/bin/env bash
set -eu

cd "$(git rev-parse --show-toplevel)"
echo "→ [pre-commit] Formatting and linting staged files…"

# 一時的にステージされたファイルを処理する関数
process_staged_files() {
  local file_pattern="$1"
  local process_func="$2"

  # ステージされたファイルを取得
  mapfile -t staged_files < <(
    git diff --cached --name-only --diff-filter=ACM | grep "$file_pattern" || true
  )

  if [ "${#staged_files[@]}" -gt 0 ] && [ -n "${staged_files[0]}" ]; then
    echo "→ Processing ${#staged_files[@]} files with pattern: $file_pattern"

    # 各ファイルに対して個別に処理
    for file in "${staged_files[@]}"; do
      # ステージされた内容を一時ファイルに保存
      temp_file=$(mktemp)
      git show ":$file" > "$temp_file"

      # 一時ファイルを実際の場所にコピー
      cp "$temp_file" "$file"

      # 処理を実行
      $process_func "$file"

      # 処理結果をステージに追加
      git add "$file"

      # 一時ファイルを削除
      rm "$temp_file"
    done
  fi
}

# Ruby用の処理関数
process_ruby_file() {
  local file="$1"
  local rel="${file#backend/}"
  local docker_path="/app/${rel}"

  echo "  → Processing Ruby file: $file"
  docker compose exec -T app rubocop --force-exclusion -A "$docker_path" || true
}

# JavaScript/TypeScript用の処理関数
process_js_file() {
  local file="$1"
  local rel="${file#frontend/}"
  local docker_path="/home/node/app/${rel}"

  echo "  → Processing JS/TS file: $file"
  docker compose exec -T web npx prettier --write "$docker_path" || true
  docker compose exec -T web npx eslint --fix "$docker_path" || true
}

# ファイルを処理
process_staged_files '^backend/.*\.rb$' process_ruby_file
process_staged_files '^frontend/.*\.(js|ts|vue)$' process_js_file

echo "→ [pre-commit] All done."
